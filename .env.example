# Copy to .env and adjust for deployment

# App
APP_BASE_URL=https://app.example.com:8443
APP_DOMAIN=app.example.com

# Database (single stack: db-primary; split: VPS2 public IP)
DB_HOST=db-primary
DB_REPLICA_HOST=db-replica
DB_PORT=3306
DB_REPLICA_PORT=3306
DB_NAME=appdb
DB_USER=appuser
DB_PASSWORD=change-me-app
MYSQL_ROOT_PASSWORD=change-me-root

# Replication user (MariaDB primary -> replica)
REPL_USER=repl
REPL_PASSWORD=change-me-repl

# Redis (sessions)
REDIS_HOST=redis
REDIS_PORT=6379

# Mail (Mailpit on data node)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM=noreply@example.com

# Nginx ACL: comma-separated IPs allowed for /phpmyadmin and /logs
ALLOWED_ADMIN_IPS=127.0.0.1,::1

# Single-stack: service names. Split app-node: use data node public IP + port 8081 for PMA.
PMA_UPSTREAM_HOST=phpmyadmin
PMA_UPSTREAM_PORT=80

# Split-VPS app-node overrides (uncomment on VPS1):
# DB_HOST=<VPS2-IP>
# DB_REPLICA_HOST=<VPS2-IP>
# DB_PORT=3306
# DB_REPLICA_PORT=3307
# SMTP_HOST=<VPS2-IP>
# PMA_UPSTREAM_HOST=<VPS2-IP>
# PMA_UPSTREAM_PORT=8081
