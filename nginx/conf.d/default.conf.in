upstream php_backends {
  least_conn;
  server web1:80;
  server web2:80;
}

# HTTP: ACME challenge passthrough + redirect everything else to HTTPS
server {
  listen 80;
  listen [::]:80;
  server_name ${APP_DOMAIN};

  location /.well-known/acme-challenge/ {
    root /var/www/certbot;
  }

  location / {
    return 301 https://$host$request_uri;
  }
}

server {
  listen 443 ssl;
  listen [::]:443 ssl;
  server_name ${APP_DOMAIN};

  ssl_certificate     /etc/nginx/certs/server.crt;
  ssl_certificate_key /etc/nginx/certs/server.key;
  ssl_protocols       TLSv1.2 TLSv1.3;
  ssl_ciphers         HIGH:!aNULL:!MD5;

  location / {
    proxy_pass http://php_backends;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  location /phpmyadmin/ {
    if ($admin_ok = 0) { return 403; }
    proxy_pass http://${PMA_UPSTREAM_HOST}:${PMA_UPSTREAM_PORT}/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_cookie_path / /phpmyadmin/;
    proxy_buffering off;
    proxy_connect_timeout 120s;
    proxy_send_timeout 120s;
    proxy_read_timeout 120s;
  }

  location /mail/ {
    if ($admin_ok = 0) { return 403; }
    proxy_pass http://${MAILPIT_UPSTREAM_HOST}:${MAILPIT_UPSTREAM_PORT};
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
  }

  location = /logs {
    if ($admin_ok = 0) { return 403; }
    alias /var/log/nginx/goaccess.html;
    default_type text/html;
    add_header Cache-Control "no-store";
  }
}
